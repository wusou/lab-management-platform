NODE_ENV=development
API_PORT=3000
WEB_PORT=5173
DATABASE_URL=postgres://lab:lab_password@postgres:5432/lab_management
JWT_SECRET=change-me-in-production
LAB_SEED_DEMO_ACCOUNTS=true
SYNOLOGY_BASE_URL=
SYNOLOGY_USERNAME=
SYNOLOGY_PASSWORD=
SYNOLOGY_TEAM_FOLDER=
SYNOLOGY_ROOT_PATH=/实验室管理平台

# AI 模块配置（可选，不配置则 AI 功能不可用）
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
# 如果使用 OpenAI 兼容 API，取消下面注释并填写：
# AI_PROVIDER=openai
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-your-api-key
# OPENAI_MODEL=gpt-4o-mini
