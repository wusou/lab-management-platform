NODE_ENV=development
API_PORT=3000
WEB_PORT=5173
DATABASE_URL=postgres://lab:lab_password@postgres:5432/lab_management
JWT_SECRET=change-me-in-production
LAB_SEED_DEMO_ACCOUNTS=true
SYNOLOGY_BASE_URL=
SYNOLOGY_USERNAME=
SYNOLOGY_PASSWORD=
SYNOLOGY_TEAM_FOLDER=
SYNOLOGY_ROOT_PATH=/实验室管理平台

# AI 模块配置（可选，不配置则默认使用 Ollama 本地模型）
# 使用 DeepSeek 示例（推荐，OpenAI 兼容，中文效果好）：
# AI_PROVIDER=openai
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_API_KEY=sk-your-api-key
# OPENAI_MODEL=deepseek-v4-flash
# 或使用 OpenAI 官方：
# AI_PROVIDER=openai
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-your-api-key
# OPENAI_MODEL=gpt-4o-mini
# 或使用 Ollama 本地模型（默认，免费）：
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# AI 向量嵌入配置（可选，默认与 AI_PROVIDER 一致）
# EMBEDDING_PROVIDER=openai       # 嵌入模型提供商：openai 或 ollama
# EMBEDDING_MODEL=text-embedding-3-small  # OpenAI 默认
# EMBEDDING_MODEL=nomic-embed-text       # Ollama 默认（需先 ollama pull）
