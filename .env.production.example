NODE_ENV=production
API_PORT=3000
HTTP_PORT=80

POSTGRES_USER=lab
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=lab_management
DATABASE_URL=postgres://lab:change-this-strong-password@postgres:5432/lab_management

JWT_SECRET=replace-with-a-long-random-secret
LAB_SEED_DEMO_ACCOUNTS=false

SYNOLOGY_BASE_URL=
SYNOLOGY_USERNAME=
SYNOLOGY_PASSWORD=
SYNOLOGY_TEAM_FOLDER=
SYNOLOGY_ROOT_PATH=/实验室管理平台

# AI 模块配置
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b
# 或使用 OpenAI 兼容 API：
# AI_PROVIDER=openai
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-your-api-key
# OPENAI_MODEL=gpt-4o-mini
